{
  "name": "@tlabs/pi-extension-token-speed-monitor",
  "version": "1.0.0",
  "description": "Real-time tokens per second monitor for pi terminal UI",
  "type": "module",
  "main": "index.ts",
  "author": "Extension",
  "license": "MIT",
  "scripts": {
    "build": "bun run check && tsc --project tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint ./",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "validate": "bun run check && bun run lint && bun run format:check",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.1",
    "@mariozechner/pi-tui": "^0.67.1",
    "@sinclair/typebox": "^0.34.49"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.67.2",
    "@mariozechner/pi-coding-agent": "^0.67.2",
    "@mariozechner/pi-tui": "^0.67.2",
    "@sinclair/typebox": "^0.34.49",
    "@eslint/js": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.12",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "typescript-eslint": "^8.58.2"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tonussi/pi-extension-token-speed-monitor.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi",
    "tps",
    "tokens",
    "monitor",
    "pi-package",
    "token-usage",
    "speed-tracking",
    "session-analysis"
  ],
  "bugs": {
    "url": "https://github.com/tonussi/pi-extension-token-speed-monitor/issues"
  },
  "homepage": "https://github.com/tonussi/pi-extension-token-speed-monitor#readme"
}